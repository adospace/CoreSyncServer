@using Microsoft.AspNetCore.Components.Routing

<NavLink href="@Href" Match="@Match"
         class="flex items-center gap-3 px-4 py-2.5 rounded-lg transition-colors text-prussian-blue-900 hover:bg-prussian-blue-400 hover:text-white"
         ActiveClass="bg-dusk-blue-500 text-white hover:bg-dusk-blue-600">
    <span class="@IconClass size-5 shrink-0"></span>
    <span>@Label</span>
</NavLink>

@code {
    [Parameter] public string Href { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string IconClass { get; set; } = "";
    [Parameter] public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;
}
