@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="flex h-screen overflow-hidden bg-gray-50 font-sans">
    @* Mobile overlay *@
    <div id="sidebar-overlay"
         onclick="document.getElementById('sidebar').classList.add('-translate-x-full');document.getElementById('sidebar').classList.remove('translate-x-0');this.classList.add('hidden')"
         class="fixed inset-0 bg-black/50 z-20 md:hidden hidden"></div>

    @* Sidebar *@
    <aside id="sidebar"
           class="fixed inset-y-0 left-0 z-30 w-64 bg-prussian-blue-500 flex flex-col transform transition-transform duration-200 ease-in-out -translate-x-full md:translate-x-0">
        @* Logo / Brand *@
        <div class="h-16 flex items-center gap-3 px-6 shrink-0 border-b border-prussian-blue-400">
            <img src="icons/core-sync-server-36.png" alt="CoreSync" class="size-9" />
            <span class="text-lg font-semibold text-white">CoreSync</span>
        </div>

        @* Navigation *@
        <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
            <SidebarNavItem Href="/" Label="Dashboard" IconClass="i-lucide-home" Match="NavLinkMatch.All" />
            <SidebarNavItem Href="/analytics" Label="Analytics" IconClass="i-lucide-bar-chart-2" />
            <SidebarNavItem Href="/reports" Label="Reports" IconClass="i-lucide-file-text" />
            <SidebarNavItem Href="/projects" Label="Projects" IconClass="i-lucide-briefcase" />
            <SidebarNavItem Href="/data-stores" Label="Data Stores" IconClass="i-lucide-database" />
            <SidebarNavItem Href="/users" Label="Users" IconClass="i-lucide-users" />
        </nav>

        @* Settings at bottom *@
        <div class="h-16 flex items-center px-3 shrink-0 border-t border-prussian-blue-400">
            <SidebarNavItem Href="/settings" Label="Settings" IconClass="i-lucide-settings" />
        </div>
    </aside>

    @* Main content area *@
    <div class="flex-1 flex flex-col overflow-hidden md:ml-64">
        @* Top bar *@
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-4 md:px-6 shrink-0">
            <button onclick="var s=document.getElementById('sidebar');var o=document.getElementById('sidebar-overlay');s.classList.toggle('-translate-x-full');s.classList.toggle('translate-x-0');o.classList.toggle('hidden')"
                    class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors">
                <span class="i-lucide-menu size-6 text-gray-600"></span>
            </button>
            <div class="md:hidden"></div>
            <div class="hidden md:block"></div>
            <UserMenu />
        </header>

        @* Page content *@
        <main class="flex-1 overflow-y-auto p-4 md:p-6">
            @Body
        </main>
    </div>
</div>
