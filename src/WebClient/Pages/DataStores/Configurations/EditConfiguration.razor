@page "/data-stores/configurations/edit/{ConfigId:int}"
@attribute [Authorize]
@inherits InteractivePage
@implements IDisposable
@inject NavigationManager NavigationManager
@layout DashboardLayout
@rendermode InteractiveWebAssembly
@using Microsoft.AspNetCore.Authorization

<PageTitle>Edit Configuration</PageTitle>

@if (_config is null)
{
    <div class="flex items-center justify-center py-12">
        <div class="flex items-center gap-3 text-gray-500">
            <div class="w-5 h-5 border-2 border-gray-300 border-t-dusk-blue-500 rounded-full animate-spin"></div>
            <span class="text-sm">Loading configuration...</span>
        </div>
    </div>
}
else
{
    <div class="space-y-6">
        @* Header *@
        <div>
            <a href="/data-stores/@_config.DataStoreId/configurations"
               class="text-sm text-dusk-blue-500 hover:text-dusk-blue-600 hover:underline flex items-center gap-1 mb-2">
                <span class="i-lucide-arrow-left size-3.5"></span>
                Back to Configurations
            </a>
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Edit Configuration</h1>
                    <p class="text-gray-500 mt-1">@_config.DataStoreName</p>
                </div>
                <div class="flex items-center gap-3">
                    <button @onclick="OpenDeleteConfigDialog"
                            class="bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg transition-colors text-sm flex items-center gap-2">
                        <span class="i-lucide-trash-2 size-4"></span>
                        Delete
                    </button>
                    <div class="h-8 w-px bg-gray-200"></div>
                    <button @onclick="SaveConfiguration" disabled="@(!HasUnsavedChanges || _isSaving)"
                            class="bg-dusk-blue-500 hover:bg-dusk-blue-600 text-white font-medium py-2 px-4 rounded-lg transition-colors text-sm flex items-center gap-2 disabled:opacity-50">
                        <span class="i-lucide-save size-4"></span>
                        @(_isSaving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>

        @* Form card *@
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            @if (_errorMessages.Count > 0)
            {
                <div class="mb-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                    @foreach (var error in _errorMessages)
                    {
                        <p class="text-sm text-ink-black-500">@error</p>
                    }
                </div>
            }

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                    <input type="text" @bind="_name" placeholder="Configuration name"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Version</label>
                    <input type="number" @bind="_version" min="1"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                    <textarea @bind="_description" rows="3" placeholder="Optional description"
                              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors resize-none"></textarea>
                </div>
            </div>
        </div>

        @* Tabs *@
        <div>
            <div class="flex border-b border-gray-200">
                <button class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors @(_activeTab == Tab.TableConfigs ? "border-dusk-blue-500 text-dusk-blue-500" : "border-transparent text-gray-500 hover:text-gray-700")"
                        @onclick="() => SwitchTab(Tab.TableConfigs)">
                    Table Configurations
                    @if (_tableConfigs is not null)
                    {
                        <span class="ml-1.5 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">@_tableConfigs.Count</span>
                    }
                </button>
                <button class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors @(_activeTab == Tab.Endpoints ? "border-dusk-blue-500 text-dusk-blue-500" : "border-transparent text-gray-500 hover:text-gray-700")"
                        @onclick="() => SwitchTab(Tab.Endpoints)">
                    Endpoints
                    @if (_endpoints is not null)
                    {
                        <span class="ml-1.5 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">@_endpoints.Count</span>
                    }
                </button>
            </div>

            <div class="mt-4">
                @if (_activeTab == Tab.TableConfigs)
                {
                    <DataGrid Loading="@(_tableConfigs is null)"
                              LoadingMessage="Loading table configurations..."
                              EmptyIcon="i-lucide-table"
                              EmptyMessage="No table configurations yet."
                              ItemCount="@(_filteredTableConfigs?.Count() ?? 0)"
                              Pagination="@_tablePagination"
                              FilterPlaceholder="Search tables..."
                              FilterText="@_tableSearchText"
                              FilterTextChanged="@(v => _tableSearchText = v)">
                        <ToolbarContent>
                            <button @onclick="OpenCreateTableDialog"
                                    class="bg-dusk-blue-500 hover:bg-dusk-blue-600 text-white font-medium py-1.5 px-3 rounded-lg transition-colors text-sm flex items-center gap-1.5">
                                <span class="i-lucide-plus size-3.5"></span>
                                Add Table
                            </button>
                            <button @onclick="ScaffoldTables" disabled="@_isScaffolding"
                                    class="bg-gray-600 hover:bg-gray-700 text-white font-medium py-1.5 px-3 rounded-lg transition-colors text-sm flex items-center gap-1.5 disabled:opacity-50">
                                <span class="i-lucide-database size-3.5"></span>
                                @(_isScaffolding ? "Scaffolding..." : "Scaffold")
                            </button>
                            <button @onclick="SortTables" disabled="@_isSorting"
                                    class="bg-gray-600 hover:bg-gray-700 text-white font-medium py-1.5 px-3 rounded-lg transition-colors text-sm flex items-center gap-1.5 disabled:opacity-50">
                                <span class="i-lucide-arrow-up-down size-3.5"></span>
                                @(_isSorting ? "Sorting..." : "Sort")
                            </button>
                            @if (_selectedTableIds.Count > 0)
                            {
                                <div class="h-6 w-px bg-gray-300"></div>
                                <button @onclick="ToggleSelectAllTables"
                                        class="text-gray-600 hover:text-gray-800 font-medium py-1.5 px-3 rounded-lg hover:bg-gray-100 transition-colors text-sm flex items-center gap-1.5">
                                    <span class="i-lucide-check-square size-3.5"></span>
                                    @(AllVisibleTablesSelected ? "Deselect All" : "Select All")
                                </button>
                                <button @onclick="MarkSelectedTablesForDeletion"
                                        class="bg-red-600 hover:bg-red-700 text-white font-medium py-1.5 px-3 rounded-lg transition-colors text-sm flex items-center gap-1.5">
                                    <span class="i-lucide-trash-2 size-3.5"></span>
                                    Delete Selected (@_selectedTableIds.Count)
                                </button>
                            }
                        </ToolbarContent>
                        <ChildContent>
                            <QuickGrid Items="@_filteredTableConfigs" Pagination="@_tablePagination" Theme="custom">
                                <TemplateColumn Title="" Align="Align.Center">
                                    <input type="checkbox"
                                           checked="@_selectedTableIds.Contains(context.Id)"
                                           @onchange="() => ToggleTableSelection(context.Id)"
                                           class="size-4 rounded border-gray-300 text-dusk-blue-500 focus:ring-dusk-blue-500 cursor-pointer" />
                                </TemplateColumn>
                                <TemplateColumn Title="Sort" SortBy="@(GridSort<TableConfigDto>.ByAscending(t => t.Sort))" IsDefaultSortColumn="true">
                                    <span class="text-sm text-gray-500">@context.Sort</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Name" SortBy="@(GridSort<TableConfigDto>.ByAscending(t => t.Name))">
                                    <span class="text-sm font-medium text-gray-900">@context.Name</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Schema" SortBy="@(GridSort<TableConfigDto>.ByAscending(t => t.Schema))">
                                    <span class="text-sm text-gray-700">@(context.Schema ?? "—")</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Sync Mode" SortBy="@(GridSort<TableConfigDto>.ByAscending(t => t.SyncMode))">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @GetSyncModeStyle(context.SyncMode)">
                                        @GetSyncModeLabel(context.SyncMode)
                                    </span>
                                </TemplateColumn>
                                <TemplateColumn Title="Status" SortBy="@(GridSort<TableConfigDto>.ByDescending(t => t.InError))">
                                    @if (context.InError)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700" title="@context.Message">ERROR</span>
                                    }
                                    else if (context.Message is not null)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">@context.Message</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">OK</span>
                                    }
                                </TemplateColumn>
                                <TemplateColumn Title="Actions" Align="Align.End">
                                    <div class="flex items-center justify-end gap-1">
                                        <button @onclick="() => OpenEditTableDialog(context)"
                                                class="p-2 rounded-lg text-gray-400 hover:text-dusk-blue-500 hover:bg-gray-100 transition-colors"
                                                title="Edit table">
                                            <span class="i-lucide-pencil size-4"></span>
                                        </button>
                                        <button @onclick="() => OpenDeleteTableDialog(context)"
                                                class="p-2 rounded-lg text-gray-400 hover:text-ink-black-500 hover:bg-gray-100 transition-colors"
                                                title="Delete table">
                                            <span class="i-lucide-trash-2 size-4"></span>
                                        </button>
                                    </div>
                                </TemplateColumn>
                            </QuickGrid>
                        </ChildContent>
                    </DataGrid>
                }
                else
                {
                    <DataGrid Loading="@(_endpoints is null)"
                              LoadingMessage="Loading endpoints..."
                              EmptyIcon="i-lucide-globe"
                              EmptyMessage="No endpoints yet."
                              ItemCount="@(_filteredEndpoints?.Count() ?? 0)"
                              Pagination="@_endpointPagination"
                              FilterPlaceholder="Search endpoints..."
                              FilterText="@_endpointSearchText"
                              FilterTextChanged="@(v => _endpointSearchText = v)">
                        <ToolbarContent>
                            <button @onclick="OpenCreateEndpointDialog"
                                    class="bg-dusk-blue-500 hover:bg-dusk-blue-600 text-white font-medium py-1.5 px-3 rounded-lg transition-colors text-sm flex items-center gap-1.5">
                                <span class="i-lucide-plus size-3.5"></span>
                                Add Endpoint
                            </button>
                        </ToolbarContent>
                        <ChildContent>
                            <QuickGrid Items="@_filteredEndpoints" Pagination="@_endpointPagination" Theme="custom">
                                <TemplateColumn Title="Name" SortBy="@(GridSort<EndpointDto>.ByAscending(e => e.Name))">
                                    <span class="text-sm font-medium text-gray-900">@context.Name</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Tags" SortBy="@(GridSort<EndpointDto>.ByAscending(e => e.Tags))">
                                    <span class="text-sm text-gray-700">@(context.Tags ?? "—")</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Actions" Align="Align.End">
                                    <div class="flex items-center justify-end gap-1">
                                        <button @onclick="() => OpenEditEndpointDialog(context)"
                                                class="p-2 rounded-lg text-gray-400 hover:text-dusk-blue-500 hover:bg-gray-100 transition-colors"
                                                title="Edit endpoint">
                                            <span class="i-lucide-pencil size-4"></span>
                                        </button>
                                        <button @onclick="() => OpenDeleteEndpointDialog(context)"
                                                class="p-2 rounded-lg text-gray-400 hover:text-ink-black-500 hover:bg-gray-100 transition-colors"
                                                title="Delete endpoint">
                                            <span class="i-lucide-trash-2 size-4"></span>
                                        </button>
                                    </div>
                                </TemplateColumn>
                            </QuickGrid>
                        </ChildContent>
                    </DataGrid>
                }
            </div>
        </div>

    </div>
}

@* Unsaved changes dialog *@
@if (_showUnsavedDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="() => _showUnsavedDialog = false"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-lg bg-ink-black-900 flex items-center justify-center">
                        <span class="i-lucide-alert-triangle size-5 text-ink-black-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">Unsaved Changes</h2>
                </div>
                <p class="text-sm text-gray-600 mb-6">
                    You have unsaved changes. Are you sure you want to leave this page? Your changes will be lost.
                </p>
                <div class="flex justify-end gap-3">
                    <button @onclick="() => _showUnsavedDialog = false"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Stay
                    </button>
                    <button @onclick="DiscardAndNavigate"
                            class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors">
                        Discard Changes
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Delete configuration dialog *@
@if (_showDeleteConfigDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="() => _showDeleteConfigDialog = false"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-lg bg-ink-black-900 flex items-center justify-center">
                        <span class="i-lucide-alert-triangle size-5 text-ink-black-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">Delete Configuration</h2>
                </div>
                <p class="text-sm text-gray-600 mb-2">
                    This will permanently delete <strong>@_config?.Name</strong> and all associated table configurations and endpoints. This action cannot be undone.
                </p>
                <p class="text-sm text-gray-600 mb-4">
                    Type <strong>@_config?.Name</strong> to confirm:
                </p>
                <input type="text" @bind="_deleteConfigConfirmText" placeholder="Enter configuration name"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ink-black-500 focus:border-ink-black-500 outline-none transition-colors mb-4" />

                @if (_deleteErrorMessages.Count > 0)
                {
                    <div class="mb-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                        @foreach (var error in _deleteErrorMessages)
                        {
                            <p class="text-sm text-ink-black-500">@error</p>
                        }
                    </div>
                }

                <div class="flex justify-end gap-3">
                    <button @onclick="() => _showDeleteConfigDialog = false"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Cancel
                    </button>
                    <button @onclick="DeleteConfiguration" disabled="@(_isDeleting || _deleteConfigConfirmText != _config?.Name)"
                            class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors disabled:opacity-50">
                        @(_isDeleting ? "Deleting..." : "Delete Configuration")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Create/Edit table config dialog *@
@if (_showTableDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="CloseTableDialog"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-lg bg-dusk-blue-900 flex items-center justify-center">
                        <span class="i-lucide-table size-5 text-dusk-blue-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">@(_editingTable is null ? "Add Table Configuration" : "Edit Table Configuration")</h2>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                        <input type="text" @bind="_tableName" placeholder="Table name"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Schema</label>
                        <input type="text" @bind="_tableSchema" placeholder="Optional schema (e.g. dbo)"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Sync Mode</label>
                        <select @bind="_tableSyncMode"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors bg-white">
                            <option value="0">Upload and Download</option>
                            <option value="1">Upload Only</option>
                            <option value="2">Download Only</option>
                            <option value="3">Not Tracked</option>
                        </select>
                    </div>
                </div>

                @if (_dialogErrorMessages.Count > 0)
                {
                    <div class="mt-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                        @foreach (var error in _dialogErrorMessages)
                        {
                            <p class="text-sm text-ink-black-500">@error</p>
                        }
                    </div>
                }

                <div class="flex justify-end gap-3 mt-6">
                    <button @onclick="CloseTableDialog"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Cancel
                    </button>
                    <button @onclick="SaveTable" disabled="@(string.IsNullOrWhiteSpace(_tableName) || _isDialogSaving)"
                            class="px-4 py-2 text-sm font-medium text-white bg-dusk-blue-500 hover:bg-dusk-blue-600 rounded-lg transition-colors disabled:opacity-50">
                        @(_isDialogSaving ? "Saving..." : (_editingTable is null ? "Add" : "Save"))
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Delete table config dialog *@
@if (_showDeleteTableDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="() => _showDeleteTableDialog = false"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-lg bg-ink-black-900 flex items-center justify-center">
                        <span class="i-lucide-alert-triangle size-5 text-ink-black-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">Delete Table Configuration</h2>
                </div>
                <p class="text-sm text-gray-600 mb-2">
                    This will permanently delete <strong>@_deletingTable?.Name</strong>. This action cannot be undone.
                </p>
                <p class="text-sm text-gray-600 mb-4">
                    Type <strong>@_deletingTable?.Name</strong> to confirm:
                </p>
                <input type="text" @bind="_deleteTableConfirmText" placeholder="Enter table name"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ink-black-500 focus:border-ink-black-500 outline-none transition-colors mb-4" />

                @if (_dialogErrorMessages.Count > 0)
                {
                    <div class="mb-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                        @foreach (var error in _dialogErrorMessages)
                        {
                            <p class="text-sm text-ink-black-500">@error</p>
                        }
                    </div>
                }

                <div class="flex justify-end gap-3">
                    <button @onclick="() => _showDeleteTableDialog = false"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Cancel
                    </button>
                    <button @onclick="DeleteTable" disabled="@(_isDialogSaving || _deleteTableConfirmText != _deletingTable?.Name)"
                            class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors disabled:opacity-50">
                        @(_isDialogSaving ? "Deleting..." : "Delete Table")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Create/Edit endpoint dialog *@
@if (_showEndpointDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="CloseEndpointDialog"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-lg bg-dusk-blue-900 flex items-center justify-center">
                        <span class="i-lucide-globe size-5 text-dusk-blue-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">@(_editingEndpoint is null ? "Add Endpoint" : "Edit Endpoint")</h2>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                        <input type="text" @bind="_endpointName" placeholder="Endpoint name"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tags</label>
                        <input type="text" @bind="_endpointTags" placeholder="Optional tags (comma-separated)"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                    </div>
                </div>

                @if (_dialogErrorMessages.Count > 0)
                {
                    <div class="mt-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                        @foreach (var error in _dialogErrorMessages)
                        {
                            <p class="text-sm text-ink-black-500">@error</p>
                        }
                    </div>
                }

                <div class="flex justify-end gap-3 mt-6">
                    <button @onclick="CloseEndpointDialog"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Cancel
                    </button>
                    <button @onclick="SaveEndpoint" disabled="@(string.IsNullOrWhiteSpace(_endpointName) || _isDialogSaving)"
                            class="px-4 py-2 text-sm font-medium text-white bg-dusk-blue-500 hover:bg-dusk-blue-600 rounded-lg transition-colors disabled:opacity-50">
                        @(_isDialogSaving ? "Saving..." : (_editingEndpoint is null ? "Add" : "Save"))
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Delete endpoint dialog *@
@if (_showDeleteEndpointDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="() => _showDeleteEndpointDialog = false"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-lg bg-ink-black-900 flex items-center justify-center">
                        <span class="i-lucide-alert-triangle size-5 text-ink-black-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">Delete Endpoint</h2>
                </div>
                <p class="text-sm text-gray-600 mb-2">
                    This will permanently delete <strong>@_deletingEndpoint?.Name</strong>. This action cannot be undone.
                </p>
                <p class="text-sm text-gray-600 mb-4">
                    Type <strong>@_deletingEndpoint?.Name</strong> to confirm:
                </p>
                <input type="text" @bind="_deleteEndpointConfirmText" placeholder="Enter endpoint name"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ink-black-500 focus:border-ink-black-500 outline-none transition-colors mb-4" />

                @if (_dialogErrorMessages.Count > 0)
                {
                    <div class="mb-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                        @foreach (var error in _dialogErrorMessages)
                        {
                            <p class="text-sm text-ink-black-500">@error</p>
                        }
                    </div>
                }

                <div class="flex justify-end gap-3">
                    <button @onclick="() => _showDeleteEndpointDialog = false"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Cancel
                    </button>
                    <button @onclick="DeleteEndpoint" disabled="@(_isDialogSaving || _deleteEndpointConfirmText != _deletingEndpoint?.Name)"
                            class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors disabled:opacity-50">
                        @(_isDialogSaving ? "Deleting..." : "Delete Endpoint")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int ConfigId { get; set; }

    private enum Tab { TableConfigs, Endpoints }

    // Config detail
    private ConfigurationDetailDto? _config;
    private string _name = "";
    private string _description = "";
    private int _version;
    private string _savedName = "";
    private string _savedDescription = "";
    private int _savedVersion;
    private bool _isSaving;
    private List<string> _errorMessages = [];

    // Unsaved changes
    private IDisposable? _locationChangingRegistration;
    private bool _showUnsavedDialog;
    private string? _pendingUri;
    private bool _forceNavigate;

    // Delete config
    private bool _showDeleteConfigDialog;
    private string _deleteConfigConfirmText = "";
    private bool _isDeleting;
    private List<string> _deleteErrorMessages = [];

    // Tabs
    private Tab _activeTab = Tab.TableConfigs;

    // Table configurations
    private List<TableConfigDto>? _tableConfigs;
    private PaginationState _tablePagination = new() { ItemsPerPage = 10 };
    private string _tableSearchText = "";
    private bool _showTableDialog;
    private TableConfigDto? _editingTable;
    private string _tableName = "";
    private string _tableSchema = "";
    private int _tableSyncMode;
    private bool _isDialogSaving;
    private List<string> _dialogErrorMessages = [];

    // Selection & pending deletions
    private HashSet<int> _selectedTableIds = [];
    private HashSet<int> _pendingTableDeletions = [];

    // Scaffold & Sort
    private bool _isScaffolding;
    private bool _isSorting;

    // Delete table
    private bool _showDeleteTableDialog;
    private TableConfigDto? _deletingTable;
    private string _deleteTableConfirmText = "";

    // Endpoints
    private List<EndpointDto>? _endpoints;
    private PaginationState _endpointPagination = new() { ItemsPerPage = 10 };
    private string _endpointSearchText = "";
    private bool _showEndpointDialog;
    private EndpointDto? _editingEndpoint;
    private string _endpointName = "";
    private string _endpointTags = "";

    // Delete endpoint
    private bool _showDeleteEndpointDialog;
    private EndpointDto? _deletingEndpoint;
    private string _deleteEndpointConfirmText = "";

    private record ConfigurationDetailDto(int Id, string Name, string? Description, int Version, int DataStoreId, string DataStoreName);
    private record TableConfigDto(int Id, string Name, string? Schema, int SyncMode, bool InError, int Sort, string? Message);
    private record EndpointDto(Guid Id, string Name, string? Tags);

    private bool HasUnsavedChanges =>
        _name != _savedName || _description != _savedDescription || _version != _savedVersion
        || _pendingTableDeletions.Count > 0;

    private IQueryable<TableConfigDto>? _filteredTableConfigs =>
        _tableConfigs?.Where(t =>
            !_pendingTableDeletions.Contains(t.Id)
            && (string.IsNullOrEmpty(_tableSearchText)
                || t.Name.Contains(_tableSearchText, StringComparison.OrdinalIgnoreCase)
                || (t.Schema?.Contains(_tableSearchText, StringComparison.OrdinalIgnoreCase) ?? false))
        ).AsQueryable();

    private IQueryable<EndpointDto>? _filteredEndpoints =>
        _endpoints?.Where(e =>
            string.IsNullOrEmpty(_endpointSearchText)
            || e.Name.Contains(_endpointSearchText, StringComparison.OrdinalIgnoreCase)
            || (e.Tags?.Contains(_endpointSearchText, StringComparison.OrdinalIgnoreCase) ?? false)
        ).AsQueryable();

    protected override async Task OnInitializedInteractiveAsync()
    {
        _locationChangingRegistration = NavigationManager.RegisterLocationChangingHandler(OnLocationChanging);
        await LoadConfiguration();
        await LoadTableConfigs();
        await LoadEndpoints();
    }

    private async Task LoadConfiguration()
    {
        _config = await Http.GetFromJsonAsync<ConfigurationDetailDto>($"api/datastoreconfiguration/{ConfigId}");
        if (_config is not null)
        {
            _name = _savedName = _config.Name;
            _description = _savedDescription = _config.Description ?? "";
            _version = _savedVersion = _config.Version;
        }
    }

    private async Task LoadTableConfigs()
    {
        _tableConfigs = await Http.GetFromJsonAsync<List<TableConfigDto>>($"api/datastoreconfiguration/{ConfigId}/tables");
    }

    private async Task LoadEndpoints()
    {
        _endpoints = await Http.GetFromJsonAsync<List<EndpointDto>>($"api/datastoreconfiguration/{ConfigId}/endpoints");
    }

    // Unsaved changes
    private ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (HasUnsavedChanges && !_forceNavigate)
        {
            context.PreventNavigation();
            _pendingUri = context.TargetLocation;
            _showUnsavedDialog = true;
            StateHasChanged();
        }
        return ValueTask.CompletedTask;
    }

    private void DiscardAndNavigate()
    {
        _showUnsavedDialog = false;
        _forceNavigate = true;
        NavigationManager.NavigateTo(_pendingUri!);
    }

    public void Dispose()
    {
        _locationChangingRegistration?.Dispose();
    }

    // Save configuration
    private async Task SaveConfiguration()
    {
        _isSaving = true;
        _errorMessages = [];

        try
        {
            var request = new
            {
                Name = _name.Trim(),
                Description = string.IsNullOrWhiteSpace(_description) ? (string?)null : _description.Trim(),
                Version = _version
            };

            var response = await Http.PutAsJsonAsync($"api/datastoreconfiguration/{ConfigId}", request);

            if (response.IsSuccessStatusCode)
            {
                _savedName = _name.Trim();
                _savedDescription = _description;
                _savedVersion = _version;
                _config = _config! with { Name = _savedName, Description = _savedDescription, Version = _savedVersion };
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _errorMessages = errors ?? ["An unexpected error occurred."];
                return;
            }

            // Process pending table deletions
            if (_pendingTableDeletions.Count > 0)
            {
                var deleteErrors = new List<string>();

                foreach (var tableId in _pendingTableDeletions)
                {
                    var deleteResponse = await Http.DeleteAsync($"api/datastoreconfiguration/{ConfigId}/tables/{tableId}");
                    if (!deleteResponse.IsSuccessStatusCode)
                    {
                        var errors = await deleteResponse.Content.ReadFromJsonAsync<List<string>>();
                        deleteErrors.AddRange(errors ?? [$"Failed to delete table {tableId}."]);
                    }
                }

                _pendingTableDeletions.Clear();
                _selectedTableIds.Clear();
                await LoadTableConfigs();

                if (deleteErrors.Count > 0)
                {
                    _errorMessages = deleteErrors;
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessages = [ex.Message];
        }
        finally
        {
            _isSaving = false;
        }
    }

    // Delete configuration
    private void OpenDeleteConfigDialog()
    {
        _deleteConfigConfirmText = "";
        _deleteErrorMessages = [];
        _showDeleteConfigDialog = true;
    }

    private async Task DeleteConfiguration()
    {
        _isDeleting = true;
        _deleteErrorMessages = [];

        try
        {
            var response = await Http.DeleteAsync($"api/datastoreconfiguration/{ConfigId}");

            if (response.IsSuccessStatusCode)
            {
                _showDeleteConfigDialog = false;
                _forceNavigate = true;
                NavigationManager.NavigateTo($"/data-stores/{_config!.DataStoreId}/configurations");
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _deleteErrorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _deleteErrorMessages = [ex.Message];
        }
        finally
        {
            _isDeleting = false;
        }
    }

    // Tab switching
    private void SwitchTab(Tab tab)
    {
        _activeTab = tab;
    }

    // Table selection
    private bool AllVisibleTablesSelected =>
        _filteredTableConfigs is not null
        && _filteredTableConfigs.Any()
        && _filteredTableConfigs.All(t => _selectedTableIds.Contains(t.Id));

    private void ToggleTableSelection(int tableId)
    {
        if (!_selectedTableIds.Remove(tableId))
            _selectedTableIds.Add(tableId);
    }

    private void ToggleSelectAllTables()
    {
        if (_filteredTableConfigs is null) return;

        if (AllVisibleTablesSelected)
        {
            foreach (var t in _filteredTableConfigs)
                _selectedTableIds.Remove(t.Id);
        }
        else
        {
            foreach (var t in _filteredTableConfigs)
                _selectedTableIds.Add(t.Id);
        }
    }

    private void MarkSelectedTablesForDeletion()
    {
        _pendingTableDeletions.UnionWith(_selectedTableIds);
        _selectedTableIds.Clear();
    }

    // Sync mode helpers
    private static string GetSyncModeLabel(int mode) => mode switch
    {
        0 => "Upload & Download",
        1 => "Upload Only",
        2 => "Download Only",
        3 => "Not Tracked",
        _ => "Unknown"
    };

    private static string GetSyncModeStyle(int mode) => mode switch
    {
        0 => "bg-dusk-blue-900 text-dusk-blue-500",
        1 => "bg-green-100 text-green-700",
        2 => "bg-purple-100 text-purple-700",
        3 => "bg-gray-100 text-gray-500",
        _ => "bg-gray-100 text-gray-700"
    };

    // Table config CRUD
    private void OpenCreateTableDialog()
    {
        _editingTable = null;
        _tableName = "";
        _tableSchema = "";
        _tableSyncMode = 0;
        _dialogErrorMessages = [];
        _showTableDialog = true;
    }

    private void OpenEditTableDialog(TableConfigDto table)
    {
        _editingTable = table;
        _tableName = table.Name;
        _tableSchema = table.Schema ?? "";
        _tableSyncMode = table.SyncMode;
        _dialogErrorMessages = [];
        _showTableDialog = true;
    }

    private void CloseTableDialog()
    {
        _showTableDialog = false;
        _editingTable = null;
        _dialogErrorMessages = [];
    }

    private async Task SaveTable()
    {
        _isDialogSaving = true;
        _dialogErrorMessages = [];

        try
        {
            var request = new
            {
                Name = _tableName.Trim(),
                Schema = string.IsNullOrWhiteSpace(_tableSchema) ? (string?)null : _tableSchema.Trim(),
                SyncMode = _tableSyncMode
            };

            HttpResponseMessage response;

            if (_editingTable is null)
            {
                response = await Http.PostAsJsonAsync($"api/datastoreconfiguration/{ConfigId}/tables", request);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/datastoreconfiguration/{ConfigId}/tables/{_editingTable.Id}", request);
            }

            if (response.IsSuccessStatusCode)
            {
                CloseTableDialog();
                await LoadTableConfigs();
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _dialogErrorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _dialogErrorMessages = [ex.Message];
        }
        finally
        {
            _isDialogSaving = false;
        }
    }

    private void OpenDeleteTableDialog(TableConfigDto table)
    {
        _deletingTable = table;
        _deleteTableConfirmText = "";
        _dialogErrorMessages = [];
        _showDeleteTableDialog = true;
    }

    private async Task DeleteTable()
    {
        _isDialogSaving = true;
        _dialogErrorMessages = [];

        try
        {
            var response = await Http.DeleteAsync($"api/datastoreconfiguration/{ConfigId}/tables/{_deletingTable!.Id}");

            if (response.IsSuccessStatusCode)
            {
                _showDeleteTableDialog = false;
                _selectedTableIds.Remove(_deletingTable!.Id);
                _pendingTableDeletions.Remove(_deletingTable.Id);
                _deletingTable = null;
                await LoadTableConfigs();
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _dialogErrorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _dialogErrorMessages = [ex.Message];
        }
        finally
        {
            _isDialogSaving = false;
        }
    }

    // Scaffold & Sort
    private async Task ScaffoldTables()
    {
        _isScaffolding = true;
        _errorMessages = [];

        try
        {
            var response = await Http.PostAsync($"api/datastoreconfiguration/{ConfigId}/tables/scaffold", null);

            if (response.IsSuccessStatusCode)
            {
                _tableConfigs = await response.Content.ReadFromJsonAsync<List<TableConfigDto>>();
                _selectedTableIds.Clear();
                _pendingTableDeletions.Clear();
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _errorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _errorMessages = [ex.Message];
        }
        finally
        {
            _isScaffolding = false;
        }
    }

    private async Task SortTables()
    {
        _isSorting = true;
        _errorMessages = [];

        try
        {
            var response = await Http.PostAsync($"api/datastoreconfiguration/{ConfigId}/tables/sort", null);

            if (response.IsSuccessStatusCode)
            {
                _tableConfigs = await response.Content.ReadFromJsonAsync<List<TableConfigDto>>();
                _selectedTableIds.Clear();
                _pendingTableDeletions.Clear();
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _errorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _errorMessages = [ex.Message];
        }
        finally
        {
            _isSorting = false;
        }
    }

    // Endpoint CRUD
    private void OpenCreateEndpointDialog()
    {
        _editingEndpoint = null;
        _endpointName = "";
        _endpointTags = "";
        _dialogErrorMessages = [];
        _showEndpointDialog = true;
    }

    private void OpenEditEndpointDialog(EndpointDto endpoint)
    {
        _editingEndpoint = endpoint;
        _endpointName = endpoint.Name;
        _endpointTags = endpoint.Tags ?? "";
        _dialogErrorMessages = [];
        _showEndpointDialog = true;
    }

    private void CloseEndpointDialog()
    {
        _showEndpointDialog = false;
        _editingEndpoint = null;
        _dialogErrorMessages = [];
    }

    private async Task SaveEndpoint()
    {
        _isDialogSaving = true;
        _dialogErrorMessages = [];

        try
        {
            var request = new
            {
                Name = _endpointName.Trim(),
                Tags = string.IsNullOrWhiteSpace(_endpointTags) ? (string?)null : _endpointTags.Trim()
            };

            HttpResponseMessage response;

            if (_editingEndpoint is null)
            {
                response = await Http.PostAsJsonAsync($"api/datastoreconfiguration/{ConfigId}/endpoints", request);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/datastoreconfiguration/{ConfigId}/endpoints/{_editingEndpoint.Id}", request);
            }

            if (response.IsSuccessStatusCode)
            {
                CloseEndpointDialog();
                await LoadEndpoints();
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _dialogErrorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _dialogErrorMessages = [ex.Message];
        }
        finally
        {
            _isDialogSaving = false;
        }
    }

    private void OpenDeleteEndpointDialog(EndpointDto endpoint)
    {
        _deletingEndpoint = endpoint;
        _deleteEndpointConfirmText = "";
        _dialogErrorMessages = [];
        _showDeleteEndpointDialog = true;
    }

    private async Task DeleteEndpoint()
    {
        _isDialogSaving = true;
        _dialogErrorMessages = [];

        try
        {
            var response = await Http.DeleteAsync($"api/datastoreconfiguration/{ConfigId}/endpoints/{_deletingEndpoint!.Id}");

            if (response.IsSuccessStatusCode)
            {
                _showDeleteEndpointDialog = false;
                _deletingEndpoint = null;
                await LoadEndpoints();
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _dialogErrorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _dialogErrorMessages = [ex.Message];
        }
        finally
        {
            _isDialogSaving = false;
        }
    }
}
