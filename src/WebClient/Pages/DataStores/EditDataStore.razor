@page "/data-stores/{DataStoreId:int}/edit"
@attribute [Authorize]
@inherits InteractivePage
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@layout DashboardLayout
@rendermode InteractiveWebAssembly
@using Microsoft.AspNetCore.Authorization

<PageTitle>Edit Data Store</PageTitle>

@if (_dataStore is null)
{
    <div class="flex items-center justify-center py-12">
        <div class="flex items-center gap-3 text-gray-500">
            <div class="w-5 h-5 border-2 border-gray-300 border-t-dusk-blue-500 rounded-full animate-spin"></div>
            <span class="text-sm">Loading data store...</span>
        </div>
    </div>
}
else
{
    <div class="space-y-6">
        @* Header *@
        <div>
            <button @onclick="NavigateBack" class="text-sm text-dusk-blue-500 hover:text-dusk-blue-600 hover:underline flex items-center gap-1 mb-2">
                <span class="i-lucide-arrow-left size-3.5"></span>
                Back to Data Stores
            </button>
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Edit Data Store</h1>
                    <p class="text-gray-500 mt-1">
                        <span class="@GetTypeIconClass(_dataStore.Type) size-4 inline-block align-middle mr-1"></span>
                        @GetTypeLabel(_dataStore.Type) — @_dataStore.ProjectName
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <button @onclick="ApplyProvision" disabled="@_isProvisioning"
                            class="bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-lg transition-colors text-sm flex items-center gap-2 disabled:opacity-50">
                        <span class="i-lucide-database size-4"></span>
                        @(_isProvisioning ? "Applying..." : "Apply Provision")
                    </button>
                    <button @onclick="OpenRemoveProvisionDialog" disabled="@_isProvisioning"
                            class="bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg transition-colors text-sm flex items-center gap-2 disabled:opacity-50">
                        <span class="i-lucide-database-zap size-4"></span>
                        Remove Provision
                    </button>
                    <div class="h-8 w-px bg-gray-200"></div>
                    <button @onclick="SaveDataStore" disabled="@(!HasUnsavedChanges || !IsDetailFormValid() || _isSavingDetail)"
                            class="bg-dusk-blue-500 hover:bg-dusk-blue-600 text-white font-medium py-2 px-4 rounded-lg transition-colors text-sm flex items-center gap-2 disabled:opacity-50">
                        <span class="i-lucide-save size-4"></span>
                        @(_isSavingDetail ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>

        @* Data Store Details *@
        <div class="bg-white border border-gray-200 rounded-lg p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Data Store Details</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                    <input type="text" @bind="_editName" placeholder="Enter data store name"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                    <input type="text" @bind="_editDescription" placeholder="Optional description"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                </div>

                @switch (_dataStore.Type)
                {
                    case DataStoreType.SQLite:
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Database File Path</label>
                            <input type="text" @bind="_editFilePath" placeholder="e.g. /data/mydb.db"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors font-mono text-sm" />
                        </div>
                        break;

                    case DataStoreType.SqlServer:
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Connection String</label>
                            <input type="text" @bind="_editConnectionString" placeholder="e.g. Server=localhost;Database=MyDb;Trusted_Connection=True;"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors font-mono text-sm" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Tracking Mode</label>
                            <select @bind="_editTrackingMode"
                                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors bg-white">
                                <option value="@SqlServerDataStoreTrackingMode.ChangeTracking">Change Tracking</option>
                                <option value="@SqlServerDataStoreTrackingMode.Triggers">Triggers</option>
                            </select>
                        </div>
                        break;

                    case DataStoreType.PostgreSQL:
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Connection String</label>
                            <input type="text" @bind="_editConnectionString" placeholder="e.g. Host=localhost;Database=MyDb;Username=postgres;Password=secret"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors font-mono text-sm" />
                        </div>
                        break;
                }
            </div>

            @if (_detailErrorMessages.Count > 0)
            {
                <div class="mt-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                    @foreach (var error in _detailErrorMessages)
                    {
                        <p class="text-sm text-ink-black-500">@error</p>
                    }
                </div>
            }

            @if (_detailSuccessMessage is not null)
            {
                <div class="mt-4 p-3 bg-green-50 border border-green-200 rounded-lg flex items-center gap-2">
                    <span class="i-lucide-check-circle size-4 text-green-600"></span>
                    <p class="text-sm text-green-700">@_detailSuccessMessage</p>
                </div>
            }

        </div>

        @* Tabs *@
        <div>
            <div class="flex border-b border-gray-200">
                <button class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors @(_activeTab == Tab.Configurations ? "border-dusk-blue-500 text-dusk-blue-500" : "border-transparent text-gray-500 hover:text-gray-700")"
                        @onclick="() => _activeTab = Tab.Configurations">
                    Configurations
                    @if (_configurations is not null)
                    {
                        <span class="ml-1.5 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">@_configurations.Count</span>
                    }
                </button>
                <button class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors @(_activeTab == Tab.Endpoints ? "border-dusk-blue-500 text-dusk-blue-500" : "border-transparent text-gray-500 hover:text-gray-700")"
                        @onclick="() => _activeTab = Tab.Endpoints">
                    Endpoints
                    @if (_endpoints is not null)
                    {
                        <span class="ml-1.5 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">@_endpoints.Count</span>
                    }
                </button>
            </div>

            <div class="mt-4">
                @if (_activeTab == Tab.Configurations)
                {
                    <DataGrid Loading="@(_configurations is null)"
                              LoadingMessage="Loading configurations..."
                              EmptyIcon="i-lucide-layers"
                              EmptyMessage="No configurations found."
                              ItemCount="@(_filteredConfigurations?.Count() ?? 0)"
                              Pagination="@_pagination"
                              FilterPlaceholder="Search configurations..."
                              FilterText="@_searchText"
                              FilterTextChanged="@HandleFilter"
                              RowClickable="true"
                              OnRefresh="@LoadConfigurations">
                        <ToolbarContent>
                            <button @onclick="OpenCreateDialog"
                                    class="bg-dusk-blue-500 hover:bg-dusk-blue-600 text-white font-medium py-1.5 px-3 rounded-lg transition-colors text-sm flex items-center gap-1.5">
                                <span class="i-lucide-plus size-3.5"></span>
                                New Configuration
                            </button>
                        </ToolbarContent>
                        <ChildContent>
                            <QuickGrid Items="@_filteredConfigurations" Pagination="@_pagination" Theme="custom">
                                <TemplateColumn Title="Name" SortBy="@(GridSort<ConfigurationListDto>.ByAscending(c => c.Name))">
                                    <a href="/data-stores/configurations/edit/@context.Id" class="row-link text-sm font-medium text-dusk-blue-500 hover:text-dusk-blue-600">
                                        @context.Name
                                    </a>
                                </TemplateColumn>
                                <TemplateColumn Title="Version" SortBy="@(GridSort<ConfigurationListDto>.ByAscending(c => c.Version))">
                                    <span class="text-sm text-gray-700">v@(context.Version)</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Tables" SortBy="@(GridSort<ConfigurationListDto>.ByAscending(c => c.TableConfigCount))">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                                        @context.TableConfigCount
                                    </span>
                                </TemplateColumn>
                                <TemplateColumn Title="Endpoints" SortBy="@(GridSort<ConfigurationListDto>.ByAscending(c => c.EndpointCount))">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                                        @context.EndpointCount
                                    </span>
                                </TemplateColumn>
                                <TemplateColumn Title="Status" SortBy="@(GridSort<ConfigurationListDto>.ByDescending(c => c.InError))">
                                    @if (context.InError)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">ERROR</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">OK</span>
                                    }
                                </TemplateColumn>
                                <TemplateColumn Title="Actions" Align="Align.End">
                                    <div class="flex items-center justify-end gap-1">
                                        <a href="/data-stores/configurations/edit/@context.Id"
                                           class="p-2 rounded-lg text-gray-400 hover:text-dusk-blue-500 hover:bg-gray-100 transition-colors"
                                           title="Edit configuration">
                                            <span class="i-lucide-pencil size-4"></span>
                                        </a>
                                        <button @onclick="() => OpenDeleteDialog(context)"
                                                class="p-2 rounded-lg text-gray-400 hover:text-ink-black-500 hover:bg-gray-100 transition-colors"
                                                title="Delete configuration">
                                            <span class="i-lucide-trash-2 size-4"></span>
                                        </button>
                                    </div>
                                </TemplateColumn>
                            </QuickGrid>
                        </ChildContent>
                    </DataGrid>
                }
                else
                {
                    <DataGrid Loading="@(_endpoints is null)"
                              LoadingMessage="Loading endpoints..."
                              EmptyIcon="i-lucide-globe"
                              EmptyMessage="No endpoints yet."
                              ItemCount="@(_filteredEndpoints?.Count() ?? 0)"
                              Pagination="@_endpointPagination"
                              FilterPlaceholder="Search endpoints..."
                              FilterText="@_endpointSearchText"
                              FilterTextChanged="@(v => _endpointSearchText = v)"
                              OnRefresh="@LoadEndpoints">
                        <ToolbarContent>
                            <button @onclick="OpenCreateEndpointDialog"
                                    class="bg-dusk-blue-500 hover:bg-dusk-blue-600 text-white font-medium py-1.5 px-3 rounded-lg transition-colors text-sm flex items-center gap-1.5">
                                <span class="i-lucide-plus size-3.5"></span>
                                Add Endpoint
                            </button>
                        </ToolbarContent>
                        <ChildContent>
                            <QuickGrid Items="@_filteredEndpoints" Pagination="@_endpointPagination" Theme="custom">
                                <TemplateColumn Title="Name" SortBy="@(GridSort<EndpointListDto>.ByAscending(e => e.Name))">
                                    <span class="text-sm font-medium text-gray-900">@context.Name</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Tags" SortBy="@(GridSort<EndpointListDto>.ByAscending(e => e.Tags))">
                                    @if (!string.IsNullOrWhiteSpace(context.Tags))
                                    {
                                        <div class="flex flex-wrap gap-1">
                                            @foreach (var tag in context.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                                                    @tag.ToUpper()
                                                </span>
                                            }
                                        </div>
                                    }
                                </TemplateColumn>
                                <TemplateColumn Title="Configuration" SortBy="@(GridSort<EndpointListDto>.ByAscending(e => e.ConfigurationName))">
                                    <span class="text-sm text-gray-700">@context.ConfigurationName</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Auth">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @GetAuthTypeStyle(context.Authentication?.Type ?? -1)">
                                        @GetAuthTypeLabel(context.Authentication?.Type ?? -1)
                                    </span>
                                </TemplateColumn>
                                <TemplateColumn Title="Actions" Align="Align.End">
                                    <div class="flex items-center justify-end gap-1">
                                        <button @onclick="() => OpenEditEndpointDialog(context)"
                                                class="p-2 rounded-lg text-gray-400 hover:text-dusk-blue-500 hover:bg-gray-100 transition-colors"
                                                title="Edit endpoint">
                                            <span class="i-lucide-pencil size-4"></span>
                                        </button>
                                        <button @onclick="() => OpenDeleteEndpointDialog(context)"
                                                class="p-2 rounded-lg text-gray-400 hover:text-ink-black-500 hover:bg-gray-100 transition-colors"
                                                title="Delete endpoint">
                                            <span class="i-lucide-trash-2 size-4"></span>
                                        </button>
                                    </div>
                                </TemplateColumn>
                            </QuickGrid>
                        </ChildContent>
                    </DataGrid>
                }
            </div>
        </div>
    </div>
}

@* Create configuration dialog *@
@if (_showCreateDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="CloseCreateDialog"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-lg bg-dusk-blue-900 flex items-center justify-center">
                        <span class="i-lucide-layers size-5 text-dusk-blue-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">New Configuration</h2>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                        <input type="text" @bind="_createName" placeholder="Enter configuration name"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                    </div>
                </div>

                @if (_errorMessages.Count > 0)
                {
                    <div class="mt-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                        @foreach (var error in _errorMessages)
                        {
                            <p class="text-sm text-ink-black-500">@error</p>
                        }
                    </div>
                }

                <div class="flex justify-end gap-3 mt-6">
                    <button @onclick="CloseCreateDialog"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Cancel
                    </button>
                    <button @onclick="CreateConfiguration" disabled="@(string.IsNullOrWhiteSpace(_createName) || _isSaving)"
                            class="px-4 py-2 text-sm font-medium text-white bg-dusk-blue-500 hover:bg-dusk-blue-600 rounded-lg transition-colors disabled:opacity-50">
                        @(_isSaving ? "Creating..." : "Create")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Delete configuration dialog *@
@if (_showDeleteDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="CloseDeleteDialog"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-lg bg-ink-black-900 flex items-center justify-center">
                        <span class="i-lucide-alert-triangle size-5 text-ink-black-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">Delete Configuration</h2>
                </div>
                <p class="text-sm text-gray-600 mb-2">
                    This will permanently delete <strong>@_selectedConfig?.Name</strong> and all associated table configurations and endpoints. This action cannot be undone.
                </p>
                <p class="text-sm text-gray-600 mb-4">
                    Type <strong>@_selectedConfig?.Name</strong> to confirm:
                </p>
                <input type="text" @bind="_deleteConfirmText" placeholder="Enter configuration name"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ink-black-500 focus:border-ink-black-500 outline-none transition-colors mb-4" />

                @if (_errorMessages.Count > 0)
                {
                    <div class="mb-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                        @foreach (var error in _errorMessages)
                        {
                            <p class="text-sm text-ink-black-500">@error</p>
                        }
                    </div>
                }

                <div class="flex justify-end gap-3">
                    <button @onclick="CloseDeleteDialog"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Cancel
                    </button>
                    <button @onclick="DeleteConfiguration" disabled="@(_isSaving || _deleteConfirmText != _selectedConfig?.Name)"
                            class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors disabled:opacity-50">
                        @(_isSaving ? "Deleting..." : "Delete Configuration")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Create/Edit endpoint dialog *@
@if (_showEndpointDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="CloseEndpointDialog"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-lg" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-lg bg-dusk-blue-900 flex items-center justify-center">
                        <span class="i-lucide-globe size-5 text-dusk-blue-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">@(_editingEndpoint is null ? "Add Endpoint" : "Edit Endpoint")</h2>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                        <input type="text" @bind="_endpointName" placeholder="Endpoint name"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tags</label>
                        <input type="text" @bind="_endpointTags" placeholder="Optional tags (comma-separated)"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Configuration</label>
                        <select @bind="_endpointConfigurationId"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors bg-white">
                            @if (_configurations is not null)
                            {
                                @foreach (var config in _configurations)
                                {
                                    <option value="@config.Id">@config.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Authentication</label>
                        <select @bind="_endpointAuthType"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors bg-white">
                            <option value="-1">None</option>
                            <option value="0">Basic</option>
                            <option value="1">API Key</option>
                            <option value="2">JWT</option>
                        </select>
                    </div>
                    @if (_endpointAuthType == 0)
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                            <input type="text" @bind="_endpointAuthUsername" placeholder="Username"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                            <input type="password" @bind="_endpointAuthPassword" placeholder="Password"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                        </div>
                    }
                    else if (_endpointAuthType == 1)
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">API Key</label>
                            <input type="password" @bind="_endpointAuthApiKey" placeholder="API Key"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                        </div>
                    }
                    else if (_endpointAuthType == 2)
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">JWKS Endpoint</label>
                            <input type="text" @bind="_endpointAuthJwksEndpoint" placeholder="https://example.com/.well-known/jwks.json"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Issuer</label>
                            <input type="text" @bind="_endpointAuthIssuer" placeholder="https://example.com"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">User ID Claim</label>
                            <input type="text" @bind="_endpointAuthUserIdClaim" placeholder="sub"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">User Name Claim</label>
                            <input type="text" @bind="_endpointAuthUserNameClaim" placeholder="Optional"
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-dusk-blue-500 focus:border-dusk-blue-500 outline-none transition-colors" />
                        </div>
                    }
                </div>

                @if (_endpointErrorMessages.Count > 0)
                {
                    <div class="mt-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                        @foreach (var error in _endpointErrorMessages)
                        {
                            <p class="text-sm text-ink-black-500">@error</p>
                        }
                    </div>
                }

                <div class="flex justify-end gap-3 mt-6">
                    <button @onclick="CloseEndpointDialog"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Cancel
                    </button>
                    <button @onclick="SaveEndpoint" disabled="@(string.IsNullOrWhiteSpace(_endpointName) || _endpointConfigurationId == 0 || _isSavingEndpoint)"
                            class="px-4 py-2 text-sm font-medium text-white bg-dusk-blue-500 hover:bg-dusk-blue-600 rounded-lg transition-colors disabled:opacity-50">
                        @(_isSavingEndpoint ? "Saving..." : (_editingEndpoint is null ? "Add" : "Save"))
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Delete endpoint dialog *@
@if (_showDeleteEndpointDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="() => _showDeleteEndpointDialog = false"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-lg bg-ink-black-900 flex items-center justify-center">
                        <span class="i-lucide-alert-triangle size-5 text-ink-black-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">Delete Endpoint</h2>
                </div>
                <p class="text-sm text-gray-600 mb-2">
                    This will permanently delete <strong>@_deletingEndpoint?.Name</strong>. This action cannot be undone.
                </p>
                <p class="text-sm text-gray-600 mb-4">
                    Type <strong>@_deletingEndpoint?.Name</strong> to confirm:
                </p>
                <input type="text" @bind="_deleteEndpointConfirmText" placeholder="Enter endpoint name"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ink-black-500 focus:border-ink-black-500 outline-none transition-colors mb-4" />

                @if (_endpointErrorMessages.Count > 0)
                {
                    <div class="mb-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                        @foreach (var error in _endpointErrorMessages)
                        {
                            <p class="text-sm text-ink-black-500">@error</p>
                        }
                    </div>
                }

                <div class="flex justify-end gap-3">
                    <button @onclick="() => _showDeleteEndpointDialog = false"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Cancel
                    </button>
                    <button @onclick="DeleteEndpoint" disabled="@(_isSavingEndpoint || _deleteEndpointConfirmText != _deletingEndpoint?.Name)"
                            class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors disabled:opacity-50">
                        @(_isSavingEndpoint ? "Deleting..." : "Delete Endpoint")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Remove provision warning dialog *@
@if (_showRemoveProvisionDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="CloseRemoveProvisionDialog"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-lg bg-red-100 flex items-center justify-center">
                        <span class="i-lucide-alert-triangle size-5 text-red-600"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">Remove Provision</h2>
                </div>
                <p class="text-sm text-gray-600 mb-2">
                    This will remove all sync tracking infrastructure from the data store database. <strong>This operation could cause synchronization to stop working</strong> for any clients currently syncing with this data store.
                </p>
                <p class="text-sm text-gray-600 mb-4">
                    You will need to re-apply provision and clients may need to perform a full re-sync.
                </p>

                @if (_provisionErrorMessages.Count > 0)
                {
                    <div class="mb-4 p-3 bg-ink-black-900 border border-ink-black-700 rounded-lg">
                        @foreach (var error in _provisionErrorMessages)
                        {
                            <p class="text-sm text-ink-black-500">@error</p>
                        }
                    </div>
                }

                <div class="flex justify-end gap-3">
                    <button @onclick="CloseRemoveProvisionDialog"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Cancel
                    </button>
                    <button @onclick="RemoveProvision" disabled="@_isProvisioning"
                            class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors disabled:opacity-50">
                        @(_isProvisioning ? "Removing..." : "Remove Provision")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Provision result toast *@
@if (_provisionSuccessMessage is not null)
{
    <div class="fixed bottom-4 right-4 z-50 p-4 bg-green-100 border border-green-300 rounded-lg shadow-lg flex items-center gap-2">
        <span class="i-lucide-check-circle size-5 text-green-600"></span>
        <span class="text-sm text-green-800">@_provisionSuccessMessage</span>
        <button @onclick="() => _provisionSuccessMessage = null" class="ml-2 text-green-600 hover:text-green-800">
            <span class="i-lucide-x size-4"></span>
        </button>
    </div>
}

@* Unsaved changes dialog *@
@if (_showUnsavedDialog)
{
    <div class="fixed inset-0 z-40 bg-black/50" @onclick="() => _showUnsavedDialog = false"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded border border-gray-200 w-full max-w-md" @onclick:stopPropagation="true">
            <div class="p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-lg bg-ink-black-900 flex items-center justify-center">
                        <span class="i-lucide-alert-triangle size-5 text-ink-black-500"></span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900">Unsaved Changes</h2>
                </div>
                <p class="text-sm text-gray-600 mb-6">
                    You have unsaved changes. Are you sure you want to leave this page? Your changes will be lost.
                </p>
                <div class="flex justify-end gap-3">
                    <button @onclick="() => _showUnsavedDialog = false"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Stay
                    </button>
                    <button @onclick="DiscardAndNavigate"
                            class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors">
                        Discard Changes
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int DataStoreId { get; set; }

    private enum Tab { Configurations, Endpoints }
    private Tab _activeTab = Tab.Configurations;

    // Data store detail
    private DataStoreDetailDto? _dataStore;
    private string _editName = "";
    private string _editDescription = "";
    private string _editFilePath = "";
    private string _editConnectionString = "";
    private SqlServerDataStoreTrackingMode _editTrackingMode;
    private string _savedName = "";
    private string _savedDescription = "";
    private string _savedFilePath = "";
    private string _savedConnectionString = "";
    private SqlServerDataStoreTrackingMode _savedTrackingMode;
    private bool _isSavingDetail;
    private List<string> _detailErrorMessages = [];
    private string? _detailSuccessMessage;

    // Unsaved changes
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<EditDataStore>? _dotNetRef;
    private bool _showUnsavedDialog;
    private string? _pendingUri;

    // Configurations
    private PaginationState _pagination = new() { ItemsPerPage = 10 };
    private List<ConfigurationListDto>? _configurations;
    private string _searchText = "";
    private bool _isSaving;
    private List<string> _errorMessages = [];

    // Create dialog
    private bool _showCreateDialog;
    private string _createName = "";

    // Delete dialog
    private bool _showDeleteDialog;
    private ConfigurationListDto? _selectedConfig;
    private string _deleteConfirmText = "";

    // Provision
    private bool _isProvisioning;
    private bool _showRemoveProvisionDialog;
    private List<string> _provisionErrorMessages = [];
    private string? _provisionSuccessMessage;

    // Endpoints
    private List<EndpointListDto>? _endpoints;
    private PaginationState _endpointPagination = new() { ItemsPerPage = 10 };
    private string _endpointSearchText = "";
    private bool _isSavingEndpoint;
    private List<string> _endpointErrorMessages = [];

    // Create/Edit endpoint dialog
    private bool _showEndpointDialog;
    private EndpointListDto? _editingEndpoint;
    private string _endpointName = "";
    private string _endpointTags = "";
    private int _endpointConfigurationId;
    private int _endpointOriginalConfigurationId;
    private int _endpointAuthType = -1; // -1 = None
    private string _endpointAuthUsername = "";
    private string _endpointAuthPassword = "";
    private string _endpointAuthApiKey = "";
    private string _endpointAuthJwksEndpoint = "";
    private string _endpointAuthIssuer = "";
    private string _endpointAuthUserIdClaim = "sub";
    private string _endpointAuthUserNameClaim = "";

    // Delete endpoint
    private bool _showDeleteEndpointDialog;
    private EndpointListDto? _deletingEndpoint;
    private string _deleteEndpointConfirmText = "";

    private IQueryable<ConfigurationListDto>? _filteredConfigurations =>
        _configurations?.Where(c =>
            string.IsNullOrEmpty(_searchText)
            || c.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
        ).AsQueryable();

    private IQueryable<EndpointListDto>? _filteredEndpoints =>
        _endpoints?.Where(e =>
            string.IsNullOrEmpty(_endpointSearchText)
            || e.Name.Contains(_endpointSearchText, StringComparison.OrdinalIgnoreCase)
            || (e.Tags?.Contains(_endpointSearchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || e.ConfigurationName.Contains(_endpointSearchText, StringComparison.OrdinalIgnoreCase)
        ).AsQueryable();

    private enum DataStoreType { SQLite, SqlServer, PostgreSQL }
    private enum SqlServerDataStoreTrackingMode { Triggers, ChangeTracking }
    private record DataStoreDetailDto(int Id, string Name, string? Description, DataStoreType Type, string ProjectName, int ProjectId, bool IsMonitorEnabled, string? FilePath, string? ConnectionString, SqlServerDataStoreTrackingMode? TrackingMode);
    private record ConfigurationListDto(int Id, string Name, string? Description, int Version, int TableConfigCount, int EndpointCount, bool InError);
    private record AuthenticationDto(int Type, string? Username, string? Password, string? ApiKey, string? JwksEndpoint, string? Issuer, string? UserIdClaim, string? UserNameClaim);
    private record EndpointListDto(Guid Id, string Name, string? Tags, int DataStoreConfigurationId, string ConfigurationName, AuthenticationDto? Authentication);

    private bool HasUnsavedChanges =>
        _editName != _savedName
        || _editDescription != _savedDescription
        || _editFilePath != _savedFilePath
        || _editConnectionString != _savedConnectionString
        || _editTrackingMode != _savedTrackingMode;

    protected override async Task OnInitializedInteractiveAsync()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
        _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/unsavedChangesGuard.js");
        await _jsModule.InvokeVoidAsync("register", _dotNetRef);
        await LoadDataStore();
        await LoadConfigurations();
        await LoadEndpoints();
    }

    private async Task LoadDataStore()
    {
        _dataStore = await Http.GetFromJsonAsync<DataStoreDetailDto>($"api/datastores/{DataStoreId}");
        if (_dataStore is not null)
        {
            _editName = _savedName = _dataStore.Name;
            _editDescription = _savedDescription = _dataStore.Description ?? "";
            _editFilePath = _savedFilePath = _dataStore.FilePath ?? "";
            _editConnectionString = _savedConnectionString = _dataStore.ConnectionString ?? "";
            _editTrackingMode = _savedTrackingMode = _dataStore.TrackingMode ?? SqlServerDataStoreTrackingMode.ChangeTracking;
        }
    }

    private void NavigateBack()
    {
        if (HasUnsavedChanges)
        {
            _pendingUri = "/data-stores";
            _showUnsavedDialog = true;
        }
        else
        {
            NavigationManager.NavigateTo("/data-stores");
        }
    }

    [JSInvokable]
    public void OnNavigationAttempted(string href)
    {
        if (HasUnsavedChanges)
        {
            _pendingUri = href;
            _showUnsavedDialog = true;
            StateHasChanged();
        }
        else
        {
            NavigationManager.NavigateTo(href);
        }
    }

    private void DiscardAndNavigate()
    {
        _showUnsavedDialog = false;
        NavigationManager.NavigateTo(_pendingUri!);
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            await _jsModule.InvokeVoidAsync("unregister");
            await _jsModule.DisposeAsync();
        }
        _dotNetRef?.Dispose();
    }

    private async Task LoadConfigurations()
    {
        _configurations = await Http.GetFromJsonAsync<List<ConfigurationListDto>>($"api/datastoreconfigurations?dataStoreId={DataStoreId}");
    }

    private async Task LoadEndpoints()
    {
        _endpoints = await Http.GetFromJsonAsync<List<EndpointListDto>>($"api/datastores/{DataStoreId}/endpoints");
    }

    private void HandleFilter(string value) => _searchText = value;

    private static string GetTypeIconClass(DataStoreType type) => type switch
    {
        DataStoreType.SQLite => "i-simple-icons-sqlite",
        DataStoreType.SqlServer => "i-simple-icons-microsoftsqlserver",
        DataStoreType.PostgreSQL => "i-simple-icons-postgresql",
        _ => "i-lucide-database"
    };

    private static string GetTypeLabel(DataStoreType type) => type switch
    {
        DataStoreType.SQLite => "SQLite",
        DataStoreType.SqlServer => "SQL Server",
        DataStoreType.PostgreSQL => "PostgreSQL",
        _ => "Unknown"
    };

    // Data store detail save
    private bool IsDetailFormValid() => !string.IsNullOrWhiteSpace(_editName);

    private async Task SaveDataStore()
    {
        _isSavingDetail = true;
        _detailErrorMessages = [];
        _detailSuccessMessage = null;

        try
        {
            var request = new
            {
                Name = _editName.Trim(),
                Description = string.IsNullOrWhiteSpace(_editDescription) ? (string?)null : _editDescription.Trim(),
                FilePath = _dataStore!.Type == DataStoreType.SQLite ? _editFilePath.Trim() : (string?)null,
                ConnectionString = _dataStore.Type is DataStoreType.SqlServer or DataStoreType.PostgreSQL ? _editConnectionString.Trim() : (string?)null,
                TrackingMode = _dataStore.Type == DataStoreType.SqlServer ? _editTrackingMode : (SqlServerDataStoreTrackingMode?)null
            };

            var response = await Http.PutAsJsonAsync($"api/datastores/{DataStoreId}", request);

            if (response.IsSuccessStatusCode)
            {
                _detailSuccessMessage = "Data store updated successfully.";
                await LoadDataStore();
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _detailErrorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _detailErrorMessages = [ex.Message];
        }
        finally
        {
            _isSavingDetail = false;
        }
    }

    // Create configuration dialog
    private void OpenCreateDialog()
    {
        _createName = "";
        _errorMessages = [];
        _showCreateDialog = true;
    }

    private void CloseCreateDialog()
    {
        _showCreateDialog = false;
        _errorMessages = [];
    }

    private async Task CreateConfiguration()
    {
        _isSaving = true;
        _errorMessages = [];

        try
        {
            var request = new { Name = _createName.Trim(), DataStoreId };
            var response = await Http.PostAsJsonAsync("api/datastoreconfigurations", request);

            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<ConfigurationListDto>();
                NavigationManager.NavigateTo($"/data-stores/configurations/edit/{created!.Id}");
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _errorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _errorMessages = [ex.Message];
        }
        finally
        {
            _isSaving = false;
        }
    }

    // Delete configuration dialog
    private void OpenDeleteDialog(ConfigurationListDto config)
    {
        _selectedConfig = config;
        _deleteConfirmText = "";
        _errorMessages = [];
        _showDeleteDialog = true;
    }

    private void CloseDeleteDialog()
    {
        _showDeleteDialog = false;
        _selectedConfig = null;
        _errorMessages = [];
    }

    private async Task DeleteConfiguration()
    {
        _isSaving = true;
        _errorMessages = [];

        try
        {
            var response = await Http.DeleteAsync($"api/datastoreconfigurations/{_selectedConfig!.Id}");

            if (response.IsSuccessStatusCode)
            {
                CloseDeleteDialog();
                await LoadConfigurations();
                await LoadEndpoints();
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _errorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _errorMessages = [ex.Message];
        }
        finally
        {
            _isSaving = false;
        }
    }

    // Endpoint management
    private static string GetAuthTypeLabel(int type) => type switch
    {
        0 => "Basic",
        1 => "API Key",
        2 => "JWT",
        _ => "None"
    };

    private static string GetAuthTypeStyle(int type) => type switch
    {
        0 => "bg-dusk-blue-900 text-dusk-blue-500",
        1 => "bg-green-100 text-green-700",
        2 => "bg-purple-100 text-purple-700",
        _ => "bg-gray-100 text-gray-500"
    };

    private void OpenCreateEndpointDialog()
    {
        _editingEndpoint = null;
        _endpointName = "";
        _endpointTags = "";
        _endpointConfigurationId = _configurations?.FirstOrDefault()?.Id ?? 0;
        _endpointOriginalConfigurationId = 0;
        ResetAuthFields();
        _endpointErrorMessages = [];
        _showEndpointDialog = true;
    }

    private void OpenEditEndpointDialog(EndpointListDto endpoint)
    {
        _editingEndpoint = endpoint;
        _endpointName = endpoint.Name;
        _endpointTags = endpoint.Tags ?? "";
        _endpointConfigurationId = endpoint.DataStoreConfigurationId;
        _endpointOriginalConfigurationId = endpoint.DataStoreConfigurationId;
        if (endpoint.Authentication is not null)
        {
            _endpointAuthType = endpoint.Authentication.Type;
            _endpointAuthUsername = endpoint.Authentication.Username ?? "";
            _endpointAuthPassword = endpoint.Authentication.Password ?? "";
            _endpointAuthApiKey = endpoint.Authentication.ApiKey ?? "";
            _endpointAuthJwksEndpoint = endpoint.Authentication.JwksEndpoint ?? "";
            _endpointAuthIssuer = endpoint.Authentication.Issuer ?? "";
            _endpointAuthUserIdClaim = endpoint.Authentication.UserIdClaim ?? "sub";
            _endpointAuthUserNameClaim = endpoint.Authentication.UserNameClaim ?? "";
        }
        else
        {
            ResetAuthFields();
        }
        _endpointErrorMessages = [];
        _showEndpointDialog = true;
    }

    private void CloseEndpointDialog()
    {
        _showEndpointDialog = false;
        _editingEndpoint = null;
        _endpointErrorMessages = [];
    }

    private void ResetAuthFields()
    {
        _endpointAuthType = -1;
        _endpointAuthUsername = "";
        _endpointAuthPassword = "";
        _endpointAuthApiKey = "";
        _endpointAuthJwksEndpoint = "";
        _endpointAuthIssuer = "";
        _endpointAuthUserIdClaim = "sub";
        _endpointAuthUserNameClaim = "";
    }

    private async Task SaveEndpoint()
    {
        _isSavingEndpoint = true;
        _endpointErrorMessages = [];

        try
        {
            var auth = _endpointAuthType >= 0 ? new AuthenticationDto(
                _endpointAuthType,
                _endpointAuthType == 0 ? _endpointAuthUsername.Trim() : null,
                _endpointAuthType == 0 ? _endpointAuthPassword.Trim() : null,
                _endpointAuthType == 1 ? _endpointAuthApiKey.Trim() : null,
                _endpointAuthType == 2 ? _endpointAuthJwksEndpoint.Trim() : null,
                _endpointAuthType == 2 ? _endpointAuthIssuer.Trim() : null,
                _endpointAuthType == 2 ? (string.IsNullOrWhiteSpace(_endpointAuthUserIdClaim) ? "sub" : _endpointAuthUserIdClaim.Trim()) : null,
                _endpointAuthType == 2 ? (string.IsNullOrWhiteSpace(_endpointAuthUserNameClaim) ? null : _endpointAuthUserNameClaim.Trim()) : null
            ) : (AuthenticationDto?)null;

            var request = new
            {
                Name = _endpointName.Trim(),
                Tags = string.IsNullOrWhiteSpace(_endpointTags) ? (string?)null : _endpointTags.Trim(),
                Authentication = auth
            };

            HttpResponseMessage response;

            if (_editingEndpoint is null)
            {
                response = await Http.PostAsJsonAsync($"api/datastoreconfigurations/{_endpointConfigurationId}/endpoints", request);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/datastoreconfigurations/{_endpointOriginalConfigurationId}/endpoints/{_editingEndpoint.Id}", request);

                // If configuration changed, move the endpoint
                if (response.IsSuccessStatusCode && _endpointConfigurationId != _endpointOriginalConfigurationId)
                {
                    var moveRequest = new { DataStoreConfigurationId = _endpointConfigurationId };
                    response = await Http.PutAsJsonAsync($"api/datastores/{DataStoreId}/endpoints/{_editingEndpoint.Id}/configuration", moveRequest);
                }
            }

            if (response.IsSuccessStatusCode)
            {
                CloseEndpointDialog();
                await LoadEndpoints();
                await LoadConfigurations();
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _endpointErrorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _endpointErrorMessages = [ex.Message];
        }
        finally
        {
            _isSavingEndpoint = false;
        }
    }

    private void OpenDeleteEndpointDialog(EndpointListDto endpoint)
    {
        _deletingEndpoint = endpoint;
        _deleteEndpointConfirmText = "";
        _endpointErrorMessages = [];
        _showDeleteEndpointDialog = true;
    }

    private async Task DeleteEndpoint()
    {
        _isSavingEndpoint = true;
        _endpointErrorMessages = [];

        try
        {
            var response = await Http.DeleteAsync($"api/datastoreconfigurations/{_deletingEndpoint!.DataStoreConfigurationId}/endpoints/{_deletingEndpoint.Id}");

            if (response.IsSuccessStatusCode)
            {
                _showDeleteEndpointDialog = false;
                _deletingEndpoint = null;
                await LoadEndpoints();
                await LoadConfigurations();
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _endpointErrorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _endpointErrorMessages = [ex.Message];
        }
        finally
        {
            _isSavingEndpoint = false;
        }
    }

    // Provision
    private async Task ApplyProvision()
    {
        _isProvisioning = true;
        _provisionSuccessMessage = null;
        _provisionErrorMessages = [];

        try
        {
            var response = await Http.PostAsync($"api/provision/{DataStoreId}/apply", null);

            if (response.IsSuccessStatusCode)
            {
                _provisionSuccessMessage = "Provision applied successfully.";
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _provisionErrorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _provisionErrorMessages = [ex.Message];
        }
        finally
        {
            _isProvisioning = false;
        }
    }

    private void OpenRemoveProvisionDialog()
    {
        _provisionErrorMessages = [];
        _showRemoveProvisionDialog = true;
    }

    private void CloseRemoveProvisionDialog()
    {
        _showRemoveProvisionDialog = false;
        _provisionErrorMessages = [];
    }

    private async Task RemoveProvision()
    {
        _isProvisioning = true;
        _provisionErrorMessages = [];

        try
        {
            var response = await Http.PostAsync($"api/provision/{DataStoreId}/remove", null);

            if (response.IsSuccessStatusCode)
            {
                CloseRemoveProvisionDialog();
                _provisionSuccessMessage = "Provision removed successfully.";
            }
            else
            {
                var errors = await response.Content.ReadFromJsonAsync<List<string>>();
                _provisionErrorMessages = errors ?? ["An unexpected error occurred."];
            }
        }
        catch (Exception ex)
        {
            _provisionErrorMessages = [ex.Message];
        }
        finally
        {
            _isProvisioning = false;
        }
    }
}
